// ─── Nav structure ────────────────────────────────────────────────────────────

const NAV: NavSection[] = [
  {
    title: '',
    items: [
      { href: '/dashboard',  label: 'Visión Maestra', icon: Icon.vision },
      { href: '/objetivos',  label: 'Objetivos',      icon: Icon.objectives },
    ],
  },
  {
    title: 'Marketing',
    collapsible: true,
    items: [
      { href: '/marketing',         label: 'Visión de Marketing', icon: Icon.vision },
      { href: '/marketing/web',     label: 'Página Web',          icon: Icon.chart },
      { href: '/marketing/seo',     label: 'Google SEO',          icon: Icon.chart },
      { href: '/marketing/ads',     label: 'Google Ads',          icon: Icon.chart },
    ],
  },
  {
    title: 'Ventas',
    collapsible: true,
    items: [
      { href: '/ventas/vision',           label: 'Visión de Ventas',  icon: Icon.vision },
      { href: '/ventas/contactos',        label: 'Contactos',         icon: Icon.contacts },
      { href: '/ventas/leads-relevantes', label: 'Leads Relevantes',  icon: Icon.leads },
      { href: '/ventas/propuestas',       label: 'Propuestas',        icon: Icon.proposals },
      { href: '/ventas/pedidos',          label: 'Pedidos',           icon: Icon.orders },
      { href: '/ventas/clientes',         label: 'Clientes',          icon: Icon.clients },
    ],
  },
  {
    title: 'Proyectos',
    collapsible: true,
    items: [
      { href: '/proyectos', label: 'Proyectos', icon: Icon.projects },
    ],
  },
  {
    title: 'Configuración',
    collapsible: true,
    items: [
      { href: '/perfil',                      label: 'Mi perfil',    icon: Icon.user },
      { href: '/configuracion/cuenta',        label: 'Cuenta',       icon: Icon.settings },
      { href: '/configuracion/organizacion',  label: 'Organización', icon: Icon.settings },
      { href: '/configuracion/equipo',        label: 'Equipo',       icon: Icon.settings },
      { href: '/configuracion/integraciones', label: 'Integraciones',icon: Icon.settings },
    ],
  },
]

// ─── NavLink ──────────────────────────────────────────────────────────────────

function NavLink({ href, label, icon }: NavItem) {
  const pathname = usePathname()
  const isActive = pathname === href || (href !== '/dashboard' && pathname.startsWith(href))

  return (
    <Link
      href={href}
      className={`flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-all ${
        isActive ? 'bg-white/10 text-white font-medium' : 'text-slate-400 hover:text-white hover:bg-white/5'
      }`}
    >
      <span className={isActive ? 'text-emerald-400' : 'text-slate-500'}>{icon}</span>
      {label}
    </Link>
  )
}

// ─── NavSection ───────────────────────────────────────────────────────────────

function NavSection({ section }: { section: NavSection }) {
  const pathname  = usePathname()
  const hasActive = section.items.some(i =>
    pathname === i.href || (i.href !== '/dashboard' && pathname.startsWith(i.href))
  )
  const [open, setOpen] = useState(hasActive || !section.collapsible)

  return (
    <div>
      {section.title && (
        <button
          onClick={() => section.collapsible && setOpen(v => !v)}
          className="w-full flex items-center justify-between px-3 pt-4 pb-1"
        >
          <span className="text-xs font-semibold uppercase tracking-widest text-slate-500">
            {section.title}
          </span>
          {section.collapsible && (
            <svg className={`w-3 h-3 text-slate-600 transition-transform ${open ? '' : '-rotate-90'}`}
              fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
            </svg>
          )}
        </button>
      )}
      {open && (
        <div className="space-y-0.5">
          {section.items.map(item => <NavLink key={item.href} {...item} />)}
        </div>
      )}
    </div>
  )
}

// ─── Main ─────────────────────────────────────────────────────────────────────

export default function Sidebar({ orgName, orgId, logoSignedUrl }: Props) {
  const [imgError, setImgError] = useState(false)

  const initials  = orgName
    ? orgName.split(' ').slice(0, 2).map(w => w[0]).join('').toUpperCase()
    : 'A'
  const showLogo = !!logoSignedUrl && !imgError

  return (
    <aside className="fixed top-0 left-0 bottom-0 w-56 bg-slate-900 flex flex-col z-50">

      {/* ── Fixed org header ─────────────────────────────────────────────── */}
      <div className="shrink-0 px-4 py-4 border-b border-white/10">
        <div className="flex items-center gap-3">
          <div className="w-8 h-8 rounded-lg overflow-hidden shrink-0 bg-emerald-500 flex items-center justify-center">
            {showLogo ? (
              <img
                src={logoSignedUrl}
                alt={orgName ?? 'Logo'}
                className="w-full h-full object-cover"
                onError={() => setImgError(true)}
              />
            ) : (
              <span className="text-white text-xs font-bold">{initials}</span>
            )}
          </div>
          <div className="min-w-0">
            <p className="text-white text-sm font-semibold truncate">{orgName ?? 'Antuario'}</p>
            <p className="text-slate-500 text-xs">Dashboard</p>
          </div>
        </div>
      </div>

      {/* ── Scrollable menu ──────────────────────────────────────────────── */}
      <nav className="flex-1 overflow-y-auto px-2 py-2 space-y-0.5">
        {NAV.map((section, i) => <NavSection key={i} section={section} />)}
      </nav>

      {/* ── Logout ───────────────────────────────────────────────────────── */}
      <div className="shrink-0 border-t border-white/10 px-2 py-3">
        <form action="/auth/signout" method="post">
          <button
            type="submit"
            className="w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-slate-500 hover:text-white hover:bg-white/5 transition-all"
          >
            {Icon.logout}
            Cerrar sesión
          </button>
        </form>
      </div>
    </aside>
  )
}
