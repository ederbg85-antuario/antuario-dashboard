'use client'

import { useState } from 'react'

type Props = {
  userName: string | null
  userEmail: string | null
  avatarSignedUrl: string | null   // pre-resolved signed URL from server, or null
}

const PERIODS = [
  { value: 'today',  label: 'Hoy' },
  { value: '7d',     label: '7 días' },
  { value: '30d',    label: '30 días' },
  { value: 'month',  label: 'Este mes' },
  { value: 'all',    label: 'Todo el tiempo' },
]

function getGreeting() {
  const h = new Date().getHours()
  if (h < 12) return 'Buenos días'
  if (h < 19) return 'Buenas tardes'
  return 'Buenas noches'
}

function getInitials(name: string | null, email: string | null) {
  if (name) return name.split(' ').slice(0, 2).map(n => n[0]).join('').toUpperCase()
  if (email) return email[0].toUpperCase()
  return 'U'
}

function getFirstName(name: string | null, email: string | null) {
  if (name) return name.split(' ')[0]
  if (email) return email.split('@')[0]
  return 'Usuario'
}

export default function Topbar({ userName, userEmail, avatarSignedUrl }: Props) {
  const [period,      setPeriod]      = useState('30d')
  const [showPeriods, setShowPeriods] = useState(false)
  const [imgError,    setImgError]    = useState(false)

  const firstName   = getFirstName(userName, userEmail)
  const initials    = getInitials(userName, userEmail)
  const greeting    = getGreeting()
  const periodLabel = PERIODS.find(p => p.value === period)?.label ?? '30 días'
  const showImg     = !!avatarSignedUrl && !imgError

  return (
    <header className="fixed top-0 left-56 right-0 h-14 bg-white border-b border-slate-200 z-40 flex items-center justify-between px-6">

      {/* Left — greeting */}
      <p className="text-sm text-slate-600">
        <span className="text-slate-400">{greeting}, </span>
        <span className="font-semibold text-slate-800">{firstName}</span>
        <span className="text-slate-400 hidden md:inline"> · me alegra verte de nuevo</span>
      </p>

      {/* Right — period + user */}
      <div className="flex items-center gap-3">

        {/* Period selector */}
        <div className="relative">
          <button
            onClick={() => setShowPeriods(v => !v)}
            className="flex items-center gap-2 border border-slate-200 rounded-lg px-3 py-1.5 text-sm text-slate-600 hover:bg-slate-50 transition-colors"
          >
            <svg className="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {periodLabel}
            <svg className="w-3 h-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          {showPeriods && (
            <>
              <div className="fixed inset-0 z-40" onClick={() => setShowPeriods(false)} />
              <div className="absolute right-0 top-full mt-1 bg-white border border-slate-200 rounded-xl shadow-lg py-1 w-36 z-50">
                {PERIODS.map(p => (
                  <button
                    key={p.value}
                    onClick={() => { setPeriod(p.value); setShowPeriods(false) }}
                    className={`w-full text-left px-3 py-2 text-sm transition-colors ${
                      period === p.value ? 'bg-slate-900 text-white' : 'text-slate-600 hover:bg-slate-50'
                    }`}
                  >
                    {p.label}
                  </button>
                ))}
              </div>
            </>
          )}
        </div>

        {/* User + avatar */}
        <div className="flex items-center gap-2 pl-3 border-l border-slate-200">
          <div className="w-7 h-7 rounded-full overflow-hidden bg-slate-800 flex items-center justify-center shrink-0">
            {showImg ? (
              <img
                src={avatarSignedUrl}
                alt={userName ?? 'Avatar'}
                className="w-full h-full object-cover"
                onError={() => setImgError(true)}
              />
            ) : (
              <span className="text-white text-xs font-bold">{initials}</span>
            )}
          </div>
          <span className="text-sm font-medium text-slate-700 hidden sm:block truncate max-w-32">
            {userName ?? userEmail ?? 'Usuario'}
          </span>
        </div>
      </div>
    </header>
  )
}
