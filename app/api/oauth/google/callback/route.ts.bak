import { NextRequest, NextResponse } from 'next/server'
import { createClient } from '@supabase/supabase-js'
import { cookies } from 'next/headers'

// GET /api/oauth/google/callback
// Recibe el redirect de Google, intercambia code por tokens,
// obtiene info de la propiedad y guarda en marketing_connections

type OAuthState = {
  orgId:  number
  source: string
  userId: string
}

// ─── Obtener info de la propiedad conectada ───────────────────────────────────

async function getExternalInfo(
  source: string,
  accessToken: string
): Promise<{ external_id: string; external_name: string } | null> {
  try {
    if (source === 'ga4') {
      const res = await fetch(
        'https://analyticsadmin.googleapis.com/v1beta/accounts',
        { headers: { Authorization: `Bearer ${accessToken}` } }
      )
      const data = await res.json()
      const account = data.accounts?.[0]
      if (!account) return null

      const propsRes = await fetch(
        `https://analyticsadmin.googleapis.com/v1beta/properties?filter=ancestor:${account.name}`,
        { headers: { Authorization: `Bearer ${accessToken}` } }
      )
      const propsData = await propsRes.json()
      const prop = propsData.properties?.[0]
      if (!prop) return { external_id: account.name, external_name: account.displayName ?? account.name }

      return {
        external_id:   prop.name.replace('properties/', ''),
        external_name: prop.displayName ?? prop.name,
      }
    }

    if (source === 'search_console') {
      const res = await fetch(
        'https://www.googleapis.com/webmasters/v3/sites',
        { headers: { Authorization: `Bearer ${accessToken}` } }
      )
      const data = await res.json()
      const site = data.siteEntry?.[0]
      if (!site) return null
      return {
        external_id:   site.siteUrl,
        external_name: site.siteUrl,
      }
    }

    if (source === 'google_ads') {
      const res = await fetch(
        'https://googleads.googleapis.com/v14/customers:listAccessibleCustomers',
        {
          headers: {
            Authorization:     `Bearer ${accessToken}`,
            'developer-token': process.env.GOOGLE_ADS_DEVELOPER_TOKEN ?? '',
          },
        }
      )
      const data = await res.json()
      const resourceName = data.resourceNames?.[0]
      if (!resourceName) return null
      const customerId = resourceName.replace('customers/', '')
      return {
        external_id:   customerId,
        external_name: `Cuenta Ads ${customerId}`,
      }
    }

    if (source === 'gmb') {
      const res = await fetch(
        'https://mybusinessaccountmanagement.googleapis.com/v1/accounts',
        { headers: { Authorization: `Bearer ${accessToken}` } }
      )
      const data = await res.json()
      const account = data.accounts?.[0]
      if (!account) return null
      return {
        external_id:   account.name,
        external_name: account.accountName ?? account.name,
      }
    }

    return null
  } catch (err) {
    console.error(`getExternalInfo error [${source}]:`, err)
    return null
  }
}

// ─── Route Handler ────────────────────────────────────────────────────────────

export async function GET(request: NextRequest) {
  const { searchParams } = new URL(request.url)
  const code  = searchParams.get('code')
  const state = searchParams.get('state')
  const error = searchParams.get('error')

  const baseUrl = process.env.NEXT_PUBLIC_APP_URL ?? request.nextUrl.origin
  const failUrl = (reason: string) =>
    new URL(`/configuracion/integraciones?error=${reason}`, baseUrl)

  // Google rechazó o el usuario canceló
  if (error) {
    console.error('Google OAuth error:', error)
    return NextResponse.redirect(failUrl(error))
  }

  if (!code || !state) {
    return NextResponse.redirect(failUrl('missing_params'))
  }

  // Decodificar state
  let parsed: OAuthState
  try {
    parsed = JSON.parse(Buffer.from(state, 'base64url').toString('utf-8'))
  } catch {
    // Fallback: intentar base64 normal (compatibilidad con versión anterior)
    try {
      parsed = JSON.parse(atob(state))
    } catch {
      return NextResponse.redirect(failUrl('invalid_state'))
    }
  }

  const { orgId, source, userId } = parsed

  if (!orgId || !source || !userId) {
    return NextResponse.redirect(failUrl('invalid_state_fields'))
  }

  // ── Intercambiar code por tokens ────────────────────────────────────────────

  const tokenRes = await fetch('https://oauth2.googleapis.com/token', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: new URLSearchParams({
      code,
      client_id:     process.env.GOOGLE_CLIENT_ID!,
      client_secret: process.env.GOOGLE_CLIENT_SECRET!,
      redirect_uri:  `${baseUrl}/api/oauth/google/callback`,
      grant_type:    'authorization_code',
    }),
  })

  if (!tokenRes.ok) {
    const err = await tokenRes.json()
    console.error('Token exchange failed:', err)
    return NextResponse.redirect(failUrl('token_exchange_failed'))
  }

  const tokens = await tokenRes.json()
  const { access_token, refresh_token, expires_in } = tokens

  // ── CRÍTICO: Si no viene refresh_token, la conexión no es útil ──────────────
  // Esto pasa cuando el usuario ya autorizó antes y Google no lo reenvía.
  // Por eso usamos prompt=consent en el connect — para forzarlo siempre.
  if (!refresh_token) {
    console.warn(`No refresh_token received for source=${source}. El usuario ya había autorizado.`)
    // No es fatal — guardamos igual pero logueamos para debug
  }

  const expiresAt = new Date(Date.now() + (expires_in ?? 3600) * 1000)

  // ── Obtener info de la propiedad ───────────────────────────────────────────
  const externalInfo = await getExternalInfo(source, access_token)

  // ── Guardar en Supabase con service_role (bypass RLS) ─────────────────────
  // Usamos createClient directo (no SSR) para evitar depender de cookies
  // en esta ruta de API — el service_role no necesita auth de usuario
  const supabaseAdmin = createClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.SUPABASE_SERVICE_ROLE_KEY!,
    { auth: { autoRefreshToken: false, persistSession: false } }
  )

  // Upsert: si ya existe esta org+source, actualiza tokens
  // Si external_id es null (ej. Ads sin developer token), hace upsert por org+source
  const { error: dbError } = await supabaseAdmin
    .from('marketing_connections')
    .upsert(
      {
        organization_id:  orgId,
        source,
        status:           'active',
        access_token,
        refresh_token:    refresh_token ?? null,
        token_expires_at: expiresAt.toISOString(),
        external_id:      externalInfo?.external_id   ?? null,
        external_name:    externalInfo?.external_name ?? null,
        connected_by:     userId,
        last_error:       null,
        updated_at:       new Date().toISOString(),
      },
      {
        // Si el índice único es (organization_id, source) — ajustar según schema
        onConflict:       'organization_id,source',
        ignoreDuplicates: false,
      }
    )

  if (dbError) {
    console.error('Supabase upsert error:', dbError)
    return NextResponse.redirect(failUrl('db_error'))
  }

  // ── Redirigir al dashboard correspondiente ─────────────────────────────────
  const dashboardMap: Record<string, string> = {
    ga4:            '/marketing/web',
    search_console: '/marketing/seo',
    google_ads:     '/marketing/ads',
    gmb:            '/marketing/gmb',
  }

  const successUrl = new URL(
    `${dashboardMap[source] ?? '/configuracion/integraciones'}?connected=${source}`,
    baseUrl
  )

  return NextResponse.redirect(successUrl)
}
